# ── VPS / frontend build (PUBLIC — bundled by Vite) ──────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VITE_CRM_HOSTNAME=crm.iphonerepasse.com.br
VITE_CRM_BASE_URL=https://crm.iphonerepasse.com.br
# UAZAPI server used to default a new CRM channel's subdomain (bare subdomain or full URL).
# Ex.: iatende  → iatende.uazapi.com. Server-side mirror: UAZ_SUBDOMAIN edge secret.
VITE_UAZ_SUBDOMAIN=iatende

# ── Supabase Cloud / Edge Function secrets (NEVER put in the frontend) ───────
# Gere o par com: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_SUBJECT=mailto:hospitaldosiphones@gmail.com
APP_BASE_URL=https://app.iphonerepasse.com.br
CRM_BASE_URL=https://crm.iphonerepasse.com.br
CRM_HOSTNAME=crm.iphonerepasse.com.br
PUSH_WORKER_SECRET=your_random_worker_secret

# O Supabase Cloud fornece automaticamente às Edge Functions:
# SUPABASE_URL, SUPABASE_ANON_KEY e SUPABASE_SERVICE_ROLE_KEY.
# Não copie SUPABASE_SERVICE_ROLE_KEY para a VPS ou para variáveis VITE_*.
