# PWA Push Notifications (Web Push VAPID keys)
# Gere com: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
# Para supabase/functions/.env:
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:hospitaldosiphones@gmail.com

# CRM PWA separado. Usado pelas Edge Functions para abrir a origem correta
# quando uma notificação do CRM for tocada.
CRM_BASE_URL=https://crm.iphonerepasse.com.br

# Host dedicado do CRM Plus (frontend). Usado por lib/crmRouting.ts para
# resolver product='crmplus' e montar deep links. Default:
# crm.iphonerepasse.com.br quando ausente.
VITE_CRM_HOSTNAME=crm.iphonerepasse.com.br

# Segredo de worker para autenticar chamadas server-to-server à edge function
# push-send (header `x-worker-secret`). Defina o mesmo valor em
# supabase/functions/.env. Sem ele, só o service-role JWT autentica o envio.
PUSH_WORKER_SECRET=your_push_worker_secret_here
