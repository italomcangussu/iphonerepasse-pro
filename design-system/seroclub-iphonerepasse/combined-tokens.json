{
  "project": "iPhoneRepasse x SeroClub Remix",
  "source": {
    "reference_repo": "https://github.com/italomcangussu/seroclub",
    "base_token_file": "seroclub-tokens.json",
    "strategy": "Preserve SeroClub motion + typography scale, adapt chroma to iPhoneRepasse brand and dual-theme contrast"
  },
  "colors": {
    "palette": {
      "primary": "#2563eb",
      "primary-strong": "#1d4ed8",
      "primary-soft": "#60a5fa",
      "accent": "#f97316",
      "accent-strong": "#c2410c",
      "accent-soft": "#fdba74",
      "text": "#0f172a",
      "text-secondary": "#334155",
      "text-muted": "#64748b",
      "bg": "#f8fafc",
      "bg-2": "#f1f5f9",
      "surface": "#ffffff",
      "surface-2": "#e2e8f0",
      "border": "rgba(15,23,42,0.12)",
      "border-strong": "rgba(15,23,42,0.2)",
      "success": "#16a34a",
      "warning": "#d97706",
      "error": "#dc2626",
      "info": "#0ea5e9",

      "dark-text": "#f8fafc",
      "dark-text-secondary": "#cbd5e1",
      "dark-text-muted": "#94a3b8",
      "dark-bg": "#020617",
      "dark-bg-2": "#0b1220",
      "dark-surface": "#111827",
      "dark-surface-2": "#1f2937",
      "dark-border": "rgba(148,163,184,0.25)",
      "dark-border-strong": "rgba(148,163,184,0.4)",
      "dark-primary": "#60a5fa",
      "dark-primary-strong": "#3b82f6",
      "dark-accent": "#fb923c",
      "dark-accent-strong": "#f97316",
      "dark-success": "#4ade80",
      "dark-warning": "#f59e0b",
      "dark-error": "#f87171",
      "dark-info": "#38bdf8"
    },
    "contrast_notes": {
      "light": {
        "primary_on_surface": "AA",
        "accent_on_surface": "AA (use accent-strong)",
        "text_on_bg": "AAA",
        "muted_on_bg": "AA"
      },
      "dark": {
        "primary_on_surface": "AA",
        "accent_on_surface": "AA",
        "text_on_bg": "AAA",
        "muted_on_bg": "AA"
      }
    }
  },
  "typography": {
    "google_fonts_url": "https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap",
    "families": {
      "heading": "'Plus Jakarta Sans', system-ui, sans-serif",
      "body": "'Plus Jakarta Sans', system-ui, sans-serif",
      "mono": "'Space Mono', 'JetBrains Mono', monospace"
    },
    "scale": {
      "2xs": "0.625rem",
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.5rem",
      "2xl": "2.125rem",
      "3xl": "2.75rem",
      "4xl": "3.75rem"
    },
    "weights": {
      "light": "300",
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700",
      "extrabold": "800"
    },
    "line_heights": {
      "tight": "1.1",
      "snug": "1.3",
      "normal": "1.5",
      "relaxed": "1.7"
    }
  },
  "spacing": {
    "scale": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px",
      "24": "96px"
    }
  },
  "borders": {
    "radius": {
      "xs": "2px",
      "sm": "4px",
      "md": "10px",
      "lg": "16px",
      "xl": "24px",
      "full": "9999px"
    }
  },
  "shadows": {
    "sm": "0 1px 2px rgba(15,23,42,0.08)",
    "md": "0 8px 20px rgba(15,23,42,0.12)",
    "lg": "0 20px 45px rgba(15,23,42,0.18)",
    "xl": "0 30px 70px rgba(2,6,23,0.24)",
    "glow-primary": "0 0 24px rgba(37,99,235,0.30), 0 0 60px rgba(37,99,235,0.16)",
    "glow-accent": "0 0 24px rgba(249,115,22,0.28), 0 0 60px rgba(249,115,22,0.14)",
    "inner": "inset 0 1px 0 rgba(255,255,255,0.15)"
  },
  "transitions": {
    "fast": "all 0.15s cubic-bezier(0.4, 0, 0.2, 1)",
    "default": "all 0.3s cubic-bezier(0.4, 0, 0.2, 1)",
    "slow": "all 0.45s cubic-bezier(0.4, 0, 0.2, 1)",
    "reveal": "all 0.6s cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "animations": {
    "keyframes": {
      "sm-fade-up": "from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); }",
      "sm-fade-in": "from { opacity: 0; } to { opacity: 1; }",
      "sm-glow-pulse": "0%, 100% { box-shadow: var(--shadow-glow-primary); } 50% { box-shadow: 0 0 48px rgba(37,99,235,0.5), 0 0 96px rgba(37,99,235,0.25); }",
      "sm-float": "0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); }",
      "sm-gradient-drift": "0% { transform: translate(0%, 0%) scale(1); } 33% { transform: translate(4%, -6%) scale(1.08); } 66% { transform: translate(-5%, 4%) scale(0.95); } 100% { transform: translate(0%, 0%) scale(1); }",
      "sm-shimmer": "0% { background-position: -200% center; } 100% { background-position: 200% center; }",
      "sm-orb-drift-1": "0%, 100% { transform: translate(0, 0) scale(1); } 25% { transform: translate(6%, -8%) scale(1.1); } 50% { transform: translate(-4%, 6%) scale(0.92); } 75% { transform: translate(8%, 3%) scale(1.05); }",
      "sm-orb-drift-2": "0%, 100% { transform: translate(0, 0) scale(1); } 30% { transform: translate(-7%, 5%) scale(1.12); } 60% { transform: translate(5%, -7%) scale(0.9); } 80% { transform: translate(-3%, -4%) scale(1.07); }"
    }
  },
  "gradients": [
    "linear-gradient(120deg, #1d4ed8 0%, #2563eb 45%, #f97316 100%)",
    "radial-gradient(ellipse 80% 60% at 60% 40%, rgba(37,99,235,0.16) 0%, transparent 62%)",
    "radial-gradient(ellipse 45% 45% at 12% 82%, rgba(249,115,22,0.12) 0%, transparent 55%)",
    "linear-gradient(90deg, #0f172a 0%, #1d4ed8 40%, #f97316 72%, #f8fafc 100%)"
  ],
  "background_effects": {
    "backdrop_filters": [
      "blur(12px)",
      "blur(24px) saturate(160%)"
    ],
    "blend_modes": [
      "screen"
    ]
  }
}
