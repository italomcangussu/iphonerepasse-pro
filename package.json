{
  "name": "iphonerepasse-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:deno": "rg -l \"Deno\\\\.test\" supabase/functions -g \"*.test.ts\" -g \"*.deno.ts\" | xargs deno test --sloppy-imports --node-modules-dir=auto --allow-read --allow-env --allow-net",
    "smoke:test": "playwright test -c playwright.smoke.config.ts",
    "smoke:migrations": "node scripts/smoke/migration-health.mjs",
    "smoke:severity": "node scripts/smoke/build-severity-report.mjs",
    "smoke:run": "node scripts/smoke/run-smoke.mjs",
    "preview": "vite preview",
    "start": "serve -s dist -l 3000 -c serve.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.13.5",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.563.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1",
    "serve": "^14.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^10.2.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.18",
    "web-push": "^3.6.7"
  }
}
